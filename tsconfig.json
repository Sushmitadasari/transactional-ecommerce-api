{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
"moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "worker/**/*",
    "prisma/**/*",
    "tests/**/*"
  ]
}